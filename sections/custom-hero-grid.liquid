<section class="brands-section">
  <div class="brands-section__inner">

    

    {% for block in section.blocks %}
      {% assign selected_collection = block.settings.collection %}

      {% if selected_collection != blank %}
        <div class="brand-group" {{ block.shopify_attributes }}>
          <div class="brand-header">
            <h2 class="brand-title">
              {{ selected_collection.title }}
            </h2>
          </div>

          <div class="brand-grid">
            {% for product in selected_collection.products limit: 5 %}
              <a href="{{ product.url }}" class="watch-card">
                <div class="watch-media">
                  {% if product.featured_media %}
                    <img
                      src="{{ product.featured_media | image_url: width: 700 }}"
                      alt="{{ product.featured_media.alt | default: product.title | escape }}"
                      width="{{ product.featured_media.width }}"
                      height="{{ product.featured_media.height }}"
                      loading="lazy"
                    >
                  {% else %}
                    {{ 'product-1' | placeholder_svg_tag: 'watch-placeholder' }}
                  {% endif %}

                  {% if product.compare_at_price > product.price %}
                    {% assign discount_percent = product.compare_at_price | minus: product.price | times: 100.0 | divided_by: product.compare_at_price | round %}
                    <span class="watch-badge">-{{ discount_percent }}%</span>
                  {% endif %}
                </div>

                <div class="watch-info">
                  <div class="watch-title">
                    {{ product.title }}
                  </div>

                  <div class="watch-price">
                    {% if product.compare_at_price > product.price %}
                      <span class="watch-price-old">{{ product.compare_at_price | money }}</span>
                      <span class="watch-price-new">{{ product.price | money }}</span>
                    {% else %}
                      <span class="watch-price-new">{{ product.price | money }}</span>
                    {% endif %}
                  </div>
                </div>
              </a>
            {% endfor %}
          </div>
        </div>
      {% endif %}
    {% endfor %}

    <div class="featured-brands">
        <h2 class="featured-brands__title">marcas destacadas</h2>

        <div class="featured-brands__list">
            <div class="featured-brands__item">
            <img
                src="{{ 'rolex-logo.svg' | asset_url }}"
                alt="Rolex"
                width="180"
                height="70"
                loading="lazy"
            >
            </div>

            <div class="featured-brands__item">
            <img
                src="{{ 'patek-logo.svg' | asset_url }}"
                alt="Patek Philippe"
                width="180"
                height="70"
                loading="lazy"
            >
            </div>

            <div class="featured-brands__item">
            <img
                src="{{ 'cartier-logo.svg' | asset_url }}"
                alt="Cartier"
                width="180"
                height="70"
                loading="lazy"
            >
            </div>

            <div class="featured-brands__item">
            <img
                src="{{ 'audemars-logo.svg' | asset_url }}"
                alt="Audemars Piguet"
                width="180"
                height="70"
                loading="lazy"
            >
            </div>

            <div class="featured-brands__item">
            <img
                src="{{ 'casio-logo.png' | asset_url }}"
                alt="Casio"
                width="180"
                height="70"
                loading="lazy"
            >
            </div>
        </div>
        </div>
  </div>
</section>

<style>
  .brands-section {
    margin-top: 40px;
    width: 100%;
    padding: 0 2.8rem;
  }

  .brands-section__inner {
    width: 100%;
    max-width: 1440px;
    margin: 0 auto;
  }

  .featured-brands {
    margin: 0 0 5rem;
  }

  .featured-brands__title {
    margin: 0 0 2.2rem;
    text-align: center;
    font-size: 2.8rem;
    line-height: 1.1;
    font-weight: 700;
    text-transform: lowercase;
  }

  .featured-brands__list {
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: 2.4rem;
    align-items: center;
  }

  .featured-brands__item {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 8.6rem;
    padding: 1.2rem;
    background: #fff;
  }

  .featured-brands__item img {
    max-width: 100%;
    max-height: 6.6rem;
    width: auto;
    height: auto;
    object-fit: contain;
    display: block;
  }

  .brand-group {
    margin-bottom: 56px;
  }

  .brand-header {
    margin-bottom: 18px;
  }

  .brand-title {
    font-size: 18px;
    font-weight: 700;
    letter-spacing: 1px;
    text-transform: uppercase;
    margin: 0;
  }

  .brand-grid {
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: 14px;
    width: 100%;
  }

  .watch-card {
    display: flex;
    flex-direction: column;
    height: 100%;
    text-decoration: none;
    color: inherit;
    transition: transform .2s ease;
    min-width: 0;
  }

  .watch-card:hover {
    transform: translateY(-4px);
  }

  .watch-media {
    position: relative;
    background: #f5f5f5;
    border-radius: 6px;
    overflow: hidden;
    aspect-ratio: 1 / 0.92;
  }

  .watch-card img,
  .watch-placeholder {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    background: #f5f5f5;
  }

  .watch-badge {
    position: absolute;
    top: 10px;
    right: 10px;
    background: #111;
    color: #fff;
    font-size: 11px;
    font-weight: 700;
    padding: 6px 10px;
    border-radius: 999px;
    line-height: 1;
  }

  .watch-info {
    margin-top: 10px;
    font-size: 13px;
    line-height: 1.3;
  }

  .watch-title {
    font-weight: 600;
    text-transform: uppercase;
    font-size: 13px;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    min-height: 3.4rem;
  }

  .watch-price {
    margin-top: 8px;
    display: flex;
    align-items: baseline;
    gap: 8px;
    flex-wrap: wrap;
  }

  .watch-price-old {
    color: #888;
    font-size: 12px;
    text-decoration: line-through;
  }

  .watch-price-new {
    color: #111;
    font-size: 14px;
    font-weight: 700;
  }

@media screen and (min-width: 1600px) {
    .brands-section {
      padding-left: 4rem;
      padding-right: 4rem;
    }
  }

  @media screen and (max-width: 1200px) {
    .brands-section {
      padding: 0 2.4rem;
    }

    .featured-brands__list {
      gap: 1.6rem;
    }

    .brand-grid {
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 14px;
    }
  }

  @media screen and (max-width: 990px) {
    .brands-section {
      padding: 0 1.4rem;
    }

    .featured-brands {
      margin-bottom: 4rem;
    }

    .featured-brands__title {
      font-size: 2.2rem;
      margin-bottom: 1.8rem;
    }

    .featured-brands__list {
      display: flex;
      gap: 1.2rem;
      overflow-x: auto;
      overflow-y: hidden;
      align-items: center;
      scroll-snap-type: x mandatory;
      -webkit-overflow-scrolling: touch;
      padding: 0 0 0.4rem;
    }

    .featured-brands__list::-webkit-scrollbar {
      display: none;
    }

    .featured-brands__list {
      scrollbar-width: none;
    }

    .featured-brands__item {
      flex: 0 0 16rem;
      min-height: 7.2rem;
      padding: 1rem;
      scroll-snap-align: start;
    }

    .featured-brands__item img {
      max-height: 3.8rem;
    }

    .brand-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 14px;
    }
  }

  @media screen and (max-width: 480px) {
    .brands-section {
      padding: 0 1rem;
    }

    .featured-brands__list {
      display: flex;
      gap: 1rem;
      overflow-x: auto;
      overflow-y: hidden;
      scroll-snap-type: x mandatory;
      -webkit-overflow-scrolling: touch;
      padding: 0 0 0.4rem;
      margin-right: -0.2rem;
    }

    .featured-brands__item {
      flex: 0 0 13.5rem;
      min-height: 6.8rem;
      padding: 0.9rem;
      scroll-snap-align: start;
    }

    .featured-brands__title {
      font-size: 2rem;
    }

    .featured-brands__item img {
      max-height: 3.2rem;
    }

    .brand-title {
      font-size: 16px;
    }

    .watch-title {
      font-size: 12px;
      min-height: 3.2rem;
    }

    .watch-price-new,
    .watch-price-old {
      font-size: 11px;
    }
  }
</style>

{% schema %}
{
  "name": "Brands from catalog",
  "settings": [],
  "blocks": [
    {
      "type": "brand_collection",
      "name": "Marca desde colección",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Colección a mostrar"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Brands from catalog"
    }
  ]
}
{% endschema %}