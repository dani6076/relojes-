{% comment %} Footer personalizado estilo imagen {% endcomment %}
{{ 'section-footer.css' | asset_url | stylesheet_tag }}

<footer class="custom-footer color-{{ section.settings.color_scheme }}">
  <div class="page-width">
    <div class="custom-footer__inner">

      <div class="custom-footer__col custom-footer__col--brand">
        <div class="custom-footer__brand">
          {% if section.settings.footer_logo != blank %}
            <img
              src="{{ section.settings.footer_logo | image_url: width: 400 }}"
              alt="{{ shop.name }}"
              class="custom-footer__logo"
              loading="lazy"
              width="220"
              height="auto"
            >
          {% endif %}
        </div>

        {% if section.settings.brand_description != blank %}
          <div class="custom-footer__description">
            {{ section.settings.brand_description }}
          </div>
        {% endif %}
      </div>

      <div class="custom-footer__col custom-footer__col--links">
        <h3 class="custom-footer__heading">{{ section.settings.links_heading }}</h3>

        {% if linklists[section.settings.footer_menu] != blank %}
          <ul class="custom-footer__menu list-unstyled">
            {% for link in linklists[section.settings.footer_menu].links %}
              <li>
                <a href="{{ link.url }}" class="custom-footer__link">
                  {{ link.title }}
                </a>
              </li>
            {% endfor %}
          </ul>
        {% endif %}
      </div>

      <div class="custom-footer__col custom-footer__col--contact">
        <h3 class="custom-footer__heading">{{ section.settings.contact_heading }}</h3>

          {% if settings.phone != blank %}
            <div class="custom-footer__phone">
              <span class="custom-footer__icon custom-footer__icon--phone">
                {{ 'icon-phone-custom.svg' | inline_asset_content }}
              </span>
              <a href="tel:{{ settings.phone | replace: ' ', '' }}" class="custom-footer__link">
                {{ settings.phone }}
              </a>
            </div>
          {% endif %}

         {% if section.settings.address != blank %}
            <div class="custom-footer__address">
              <span class="custom-footer__icon custom-footer__icon--address">
                {{ 'pinMapa.svg' | inline_asset_content }}
              </span>

              <a 
                href="https://www.google.com/maps/search/?api=1&query={{ section.settings.address | url_encode }}" 
                target="_blank"
                class="custom-footer__link"
              >
                {{ section.settings.address }}
              </a>
            </div>
          {% endif %}

        <div class="custom-footer__social">
          {% if settings.social_instagram_link != blank %}
            <a
              href="{{ settings.social_instagram_link }}"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="Instagram"
              class="custom-footer__social-link"
            >
              <span class="custom-footer__social-icon">
                {{ 'icon-instagram-custom.svg' | inline_asset_content }}
              </span>
            </a>
          {% endif %}

          {% if settings.social_tiktok_link != blank %}
            <a
              href="{{ settings.social_tiktok_link }}"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="TikTok"
              class="custom-footer__social-link"
            >
              <span class="custom-footer__social-icon">
                {{ 'icon-tiktok-custom.svg' | inline_asset_content }}
              </span>
            </a>
          {% endif %}

          {% if settings.social_facebook_link != blank %}
            <a
              href="{{ settings.social_facebook_link }}"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="Facebook"
              class="custom-footer__social-link"
            >
              <span class="custom-footer__social-icon">
                {{ 'icon-facebook-custom.svg' | inline_asset_content }}
              </span>
            </a>
          {% endif %}
        </div>
      </div>

    </div>

    <div class="custom-footer__bottom">
      <p class="custom-footer__copyright">
        {{ 'now' | date: '%Y' }}. © All rights reserved. Designed by FreelDev
      </p>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer personalizado",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Esquema de color",
      "default": "scheme-1"
    },
    {
      "type": "image_picker",
      "id": "footer_logo",
      "label": "Logo del footer"
    },
    {
      "type": "textarea",
      "id": "brand_description",
      "label": "Descripción",
      "default": "Los relojes más prestigiosos del mundo en un solo lugar"
    },
    {
      "type": "text",
      "id": "links_heading",
      "label": "Título enlaces",
      "default": "Enlaces"
    },
    {
      "type": "link_list",
      "id": "footer_menu",
      "label": "Menú del footer"
    },
    {
      "type": "text",
      "id": "contact_heading",
      "label": "Título contacto",
      "default": "Contacto"
    },
    {
      "type": "text",
      "id": "phone",
      "label": "Teléfono",
      "default": "+591 12345678"
    },
    {
      "type": "textarea",
      "id": "address",
      "label": "Dirección",
      "default": "Av. Ejemplo #123, Santa Cruz, Bolivia"
    }
  ],
  "presets": [
    {
      "name": "Footer personalizado"
    }
  ]
}
{% endschema %}