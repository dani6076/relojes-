{% comment %}theme-check-disable ImgLazyLoading{% endcomment %}
{{ 'component-collection-hero.css' | asset_url | stylesheet_tag }}

{% if collection.handle == 'promociones' %}

<!-- SOLO PROMOCIONES -->
<div class="collection-hero gradient">
  <div class="hero-custom promo-clean">
    <div class="collection-hero__inner page-width">
      <div class="custom-banner">
        <div class="custom-banner__text">

          <h1 class="promo-title">
            {{ collection.title | upcase }}
          </h1>

          <p class="promo-subtitle">
            Relojes con la mejor calidad del mercado
          </p>

        </div>
      </div>
    </div>
  </div>
</div>

<style>
.promo-clean {
  background: #f6f6f6;
  justify-content: center;
  padding: 50px 20px;
}

.promo-clean .custom-banner {
  width: 100%;
  justify-content: center;
  text-align: center;
}

.promo-clean .custom-banner__text {
  width: 100%;
  max-width: 900px;
  margin: 0 auto;
}

/* MISMA BASE VISUAL DEL MENÚ */
.promo-title {
  font-family: inherit;
  font-size: 64px;
  font-weight: 500;
  text-transform: uppercase;
  color: #b07a2a;
  margin: 0 0 12px;
  letter-spacing: 0.08em;
  text-align: center;
  line-height: 1;
}

.promo-subtitle {
  font-family: inherit;
  font-size: 28px;
  color: #111111;
  margin: 0;
  font-weight: 400;
  text-align: center;
  line-height: 1.25;
}

@media screen and (max-width: 749px) {
  .promo-title {
    font-size: 34px;
  }

  .promo-subtitle {
    font-size: 18px;
  }
}
</style>

{% else %}

<!-- RESTO DEL SITIO -->
<div class="collection-hero color-{{ section.settings.color_scheme }} gradient">
  <div class="hero-custom">
    
    <div class="collection-hero__inner page-width">
      <div class="custom-banner">
        <div class="custom-banner__text">
          
          <div class="custom-banner__breadcrumb">
            <span class="crumb"><a href="/">Inicio</a></span>
            <span class="separator">/</span>

            {% if collection.handle == 'all' %}
              <span class="crumb active">Catálogo</span>
            {% else %}
              <span class="crumb"><a href="/collections/all">Catálogo</a></span>
            {% endif %}

            {% unless collection.handle == 'all' %}
              <span class="separator">/</span>
              <span class="crumb active">{{ collection.title }}</span>
            {% endunless %}
          </div>
    
          <p class="custom-banner__subtitle">
            Relojes con la mejor calidad del mercado
          </p>
          
        </div>
      </div>
    </div>

    <div class="hero-custom__image">

      <img
        class="watch-small"
        src="{{ 'icon-reloj2.png' | asset_url }}"
        alt="Reloj pequeño"
        width="800"
        height="800"
        loading="lazy"
      >

      <img
        class="watch-big"
        src="{{ 'icon-reloj.svg' | asset_url }}"
        alt="Reloj grande"
        width="800"
        height="800"
        loading="lazy"
      >

    </div>

  </div>
</div>

<style>
.hero-custom {
  width: 100%;
  min-height: 198px;
  background:
    radial-gradient(circle at 75% 50%, rgba(255,255,255,0.08), transparent 60%),
    linear-gradient(
      120deg,
      #f1f1f1 55%,
      #000000 55%,
      #111111 65%,
      #242424 80%,
      #3a3a3a 100%
    );
  position: relative;
  overflow: hidden;
  display: flex;
  align-items: center;
  padding: 0px 5%;
}

.collection-hero__inner {
  width: 100%;
}

.custom-banner {
  display: flex;
  align-items: center;
  z-index: 2;
  position: relative;
}

.custom-banner__text {
  max-width: 550px;
  padding: 20px 0;
}

.custom-banner__breadcrumb {
  display: flex;
  align-items: center;
  gap: 10px;
  margin-bottom: 8px;
}

.custom-banner__breadcrumb a,
.separator {
  text-decoration: none;
  color: #333;
  font-size: 18px;
}

.crumb.active {
  font-size: 32px;
  font-weight: 700;
  color: #000;
  margin-left: 5px;
}

.custom-banner__subtitle {
  font-size: 28px;
  color: #000;
  line-height: 1.2;
  margin: 0;
  font-weight: 400;
}

.hero-custom__image {
  position: absolute;
  right: 3%;
  top: 60%;
  transform: translateY(-50%);
  display: flex;
  align-items: center;
  gap: 0px;
  z-index: 5;
}

.hero-custom__image img {
  width: 250px;
  object-fit: contain;
  filter: drop-shadow(-15px 10px 25px rgba(0,0,0,0.5));
}
</style>

{% endif %}